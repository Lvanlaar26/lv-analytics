<!-- HERO -->
<div class="wrap">
  <div class="hero">
    <p class="hero-eyebrow">Analytics Engineering · West Michigan</p>
    <h1 class="hero-headline">
      Your data<span class="period">.</span><br>
      <strong>Actually working</strong><span class="period">.</span>
    </h1>
