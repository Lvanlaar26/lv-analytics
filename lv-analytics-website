<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="LV Analytics — Analytics engineering on retainer for growing businesses. Microsoft Fabric, Power BI, and Azure expertise without the full-time hire.">
<title>LV Analytics — Luke VanLaar</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --black:    #1C1815;
  --panel:    #2A241F;
  --panel2:   #332C26;
  --orange:   #FF6B35;
  --orange-d: rgba(255,107,53,0.12);
  --orange-m: rgba(255,107,53,0.25);
  --white:    #FDF8F3;
  --muted:    #C2B3A3;
  --dim:      #7A6E66;
  --border:   rgba(253,248,243,0.07);
  --r:        12px;
  --max:      1100px;
  --gutter:   clamp(24px, 5vw, 64px);
}

html { scroll-behavior: smooth; }

body {
  background: var(--black);
  color: var(--white);
  font-family: 'IBM Plex Sans', sans-serif;
  -webkit-font-smoothing: antialiased;
  line-height: 1.6;
}

/* ── UTILITIES ─────────────────────────────────── */
.wrap {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--gutter);
}

.orange { color: var(--orange); }
.mono { font-family: 'IBM Plex Mono', monospace; }

/* ── NAV ───────────────────────────────────────── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 20px 0;
  background: rgba(28,24,21,0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  transition: padding 0.3s ease;
}
.nav-inner {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--gutter);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.nav-logo-mark {
  width: 32px;
  height: 32px;
  flex-shrink: 0;
}
.nav-logo-text {
  display: flex;
  flex-direction: column;
  line-height: 1;
}
.nav-logo-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--white);
  letter-spacing: 0.01em;
}
.nav-logo-sub {
  font-size: 10px;
  font-weight: 400;
  color: var(--dim);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 2px;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 32px;
  list-style: none;
}
.nav-links a {
  font-size: 13px;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: 0.01em;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--white); }
.nav-cta {
  font-size: 13px;
  font-weight: 600;
  color: var(--black) !important;
  background: var(--orange);
  padding: 8px 18px;
  border-radius: 999px;
  transition: opacity 0.2s, transform 0.15s !important;
}
.nav-cta:hover { opacity: 0.9; transform: translateY(-1px); }

@media (max-width: 640px) {
  .nav-links { gap: 16px; }
  .nav-links li:not(:last-child) { display: none; }
}

/* ── HERO ──────────────────────────────────────── */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 120px var(--gutter) 80px;
  max-width: var(--max);
  margin: 0 auto;
}
.hero-eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.6s ease 0.1s forwards;
}
.hero-headline {
  font-size: clamp(42px, 7vw, 88px);
  font-weight: 300;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: var(--white);
  max-width: 820px;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.2s forwards;
}
.hero-headline strong {
  font-weight: 700;
}
.hero-headline .period { color: var(--orange); }

.hero-sub {
  margin-top: 28px;
  font-size: clamp(16px, 2vw, 20px);
  line-height: 1.65;
  color: var(--muted);
  max-width: 540px;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.35s forwards;
}

.hero-actions {
  margin-top: 44px;
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.5s forwards;
}
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--orange);
  color: var(--black);
  font-weight: 600;
  font-size: 14px;
  padding: 14px 28px;
  border-radius: 999px;
  text-decoration: none;
  transition: opacity 0.2s, transform 0.15s;
}
.btn-primary:hover { opacity: 0.9; transform: translateY(-2px); }
.btn-ghost {
  font-size: 14px;
  font-weight: 500;
  color: var(--muted);
  text-decoration: none;
  border-bottom: 1px solid var(--dim);
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.btn-ghost:hover { color: var(--white); border-color: var(--white); }

.hero-stack {
  margin-top: 60px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.65s forwards;
}
.stack-label {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--dim);
  margin-right: 4px;
}
.stack-pill {
  font-size: 12px;
  font-weight: 500;
  color: var(--muted);
  background: var(--panel);
  border: 1px solid var(--border);
  padding: 4px 12px;
  border-radius: 999px;
  letter-spacing: 0.01em;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── SECTIONS ──────────────────────────────────── */
section {
  padding: clamp(64px, 10vw, 120px) var(--gutter);
}
section .wrap { max-width: var(--max); }

.section-eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 20px;
}
.section-title {
  font-size: clamp(28px, 4vw, 44px);
  font-weight: 300;
  letter-spacing: -0.02em;
  line-height: 1.15;
  color: var(--white);
  max-width: 640px;
  margin-bottom: 24px;
}
.section-title strong { font-weight: 700; }
.section-body {
  font-size: 17px;
  line-height: 1.7;
  color: var(--muted);
  max-width: 600px;
}
.section-divider {
  height: 1px;
  background: var(--border);
  max-width: var(--max);
  margin: 0 auto;
}

/* ── PROBLEM SECTION ───────────────────────────── */
.problem {
  background: var(--panel);
}
.problem-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  margin-top: 0;
}
.problem-stat {
  padding: 40px;
  background: var(--black);
  border-radius: var(--r);
  border: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
.problem-stat::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--orange);
}
.stat-number {
  font-size: clamp(52px, 8vw, 80px);
  font-weight: 700;
  color: var(--white);
  line-height: 1;
  font-family: 'IBM Plex Mono', monospace;
  letter-spacing: -0.04em;
}
.stat-number .stat-pct { color: var(--orange); }
.stat-label {
  font-size: 15px;
  color: var(--muted);
  margin-top: 12px;
  line-height: 1.5;
}
@media (max-width: 700px) {
  .problem-grid { grid-template-columns: 1fr; gap: 40px; }
}

/* ── WHAT I DO ─────────────────────────────────── */
.whatido-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  margin-top: 56px;
  border-radius: var(--r);
  overflow: hidden;
}
.whatido-card {
  background: var(--panel);
  padding: 36px;
}
.whatido-card:nth-child(odd) { background: var(--panel2); }
.card-icon {
  width: 36px;
  height: 36px;
  margin-bottom: 20px;
  color: var(--orange);
}
.card-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 10px;
}
.card-body {
  font-size: 14px;
  line-height: 1.65;
  color: var(--muted);
}
@media (max-width: 640px) {
  .whatido-grid { grid-template-columns: 1fr; }
}

/* ── WHY THIS WORKS ────────────────────────────── */
.why {
  background: var(--panel);
}
.why-list {
  margin-top: 52px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px 64px;
}
.why-item {}
.why-num {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: var(--orange);
  font-family: 'IBM Plex Mono', monospace;
  margin-bottom: 12px;
}
.why-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 8px;
  line-height: 1.3;
}
.why-body {
  font-size: 14px;
  line-height: 1.65;
  color: var(--muted);
}
@media (max-width: 640px) {
  .why-list { grid-template-columns: 1fr; gap: 32px; }
}

/* ── TIERS ─────────────────────────────────────── */
.tiers-intro {
  max-width: 600px;
  margin-bottom: 52px;
}
.tiers-grid {
  display: flex;
  gap: 0;
  border-radius: var(--r);
  overflow: hidden;
}
.tier {
  flex: 1;
  background: var(--panel);
  padding: 36px 32px;
  position: relative;
  display: flex;
  flex-direction: column;
}
.tier + .tier {
  border-left: 1px solid var(--border);
}
.tier.featured {
  background: var(--orange);
  color: var(--black);
}
.tier-badge {
  position: absolute;
  top: -1px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--black);
  color: var(--orange);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: 0 0 8px 8px;
}
.tier-name {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.tier:not(.featured) .tier-name { color: var(--dim); }
.tier.featured .tier-name { color: rgba(28,24,21,0.6); }
.tier-price {
  font-size: 36px;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 4px;
  font-family: 'IBM Plex Mono', monospace;
  letter-spacing: -0.03em;
}
.tier:not(.featured) .tier-price { color: var(--white); }
.tier-per {
  font-size: 13px;
  font-weight: 400;
  margin-bottom: 6px;
}
.tier:not(.featured) .tier-per { color: var(--dim); }
.tier.featured .tier-per { color: rgba(28,24,21,0.55); }
.tier-tagline {
  font-size: 13px;
  font-style: italic;
  margin-bottom: 24px;
  padding-bottom: 24px;
  border-bottom: 1px solid;
  line-height: 1.4;
}
.tier:not(.featured) .tier-tagline {
  color: var(--muted);
  border-color: var(--border);
}
.tier.featured .tier-tagline {
  color: rgba(28,24,21,0.65);
  border-color: rgba(28,24,21,0.15);
}
.tier-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}
.tier-features li {
  font-size: 13px;
  display: flex;
  align-items: flex-start;
  gap: 8px;
  line-height: 1.4;
}
.tier:not(.featured) .tier-features li { color: var(--muted); }
.tier.featured .tier-features li { color: rgba(28,24,21,0.8); }
.tier-features li::before {
  content: '+';
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 0px;
  line-height: 1.4;
}
.tier:not(.featured) .tier-features li::before { color: var(--orange); }
.tier.featured .tier-features li::before { color: var(--black); }

.tiers-note {
  margin-top: 20px;
  font-size: 13px;
  color: var(--dim);
  text-align: center;
}
.tiers-note strong { color: var(--muted); font-weight: 500; }

@media (max-width: 700px) {
  .tiers-grid { flex-direction: column; }
  .tier + .tier { border-left: none; border-top: 1px solid var(--border); }
}

/* ── ABOUT ─────────────────────────────────────── */
.about {
  background: var(--panel);
}
.about-grid {
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 80px;
  align-items: start;
}
.about-body p {
  font-size: 17px;
  line-height: 1.75;
  color: var(--muted);
  margin-bottom: 20px;
}
.about-body p:last-child { margin-bottom: 0; }
.about-body p strong {
  color: var(--white);
  font-weight: 500;
}
.about-credentials {
  background: var(--black);
  border-radius: var(--r);
  border: 1px solid var(--border);
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.cred-item {
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.cred-item:last-child { border-bottom: none; padding-bottom: 0; }
.cred-item:first-child { padding-top: 0; }
.cred-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--dim);
}
.cred-value {
  font-size: 14px;
  color: var(--white);
  font-weight: 500;
}
.cred-sub {
  font-size: 12px;
  color: var(--muted);
}
@media (max-width: 800px) {
  .about-grid { grid-template-columns: 1fr; gap: 40px; }
}

/* ── CONTACT ───────────────────────────────────── */
.contact-inner {
  max-width: 640px;
  margin: 0 auto;
  text-align: center;
}
.contact-inner .section-title {
  max-width: 100%;
  margin: 0 auto 16px;
}
.contact-inner .section-body {
  max-width: 100%;
  margin: 0 auto 44px;
}
.contact-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;
}
.contact-detail {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
  margin-top: 36px;
}
.contact-item {
  font-size: 13px;
  color: var(--dim);
  display: flex;
  align-items: center;
  gap: 8px;
}
.contact-item a {
  color: var(--muted);
  text-decoration: none;
  transition: color 0.2s;
}
.contact-item a:hover { color: var(--white); }

/* ── FOOTER ────────────────────────────────────── */
footer {
  padding: 32px var(--gutter);
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  max-width: var(--max);
  margin: 0 auto;
}
.footer-copy {
  font-size: 12px;
  color: var(--dim);
}
.footer-stack {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.footer-stack span {
  font-size: 11px;
  color: var(--dim);
}
.footer-stack .stack-pill {
  font-size: 10px;
  padding: 2px 8px;
}
</style>
</head>
